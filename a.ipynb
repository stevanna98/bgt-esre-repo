    "from google.colab import drive\n",
    "drive.mount(\"/content/drive\")\n",
    "\n",
    "import time\n",
    "from datetime import datetime\n",
    "\n",
    "print(\"Kernel keep-alive started. Stop the cell to end.\")\n",
    "i = 0\n",
    "while True:\n",
    "    print(f\"[{datetime.now().strftime('%H:%M:%S')}] busy {i}\", flush=True)\n",
    "    i += 1\n",
    "    time.sleep(60)"
